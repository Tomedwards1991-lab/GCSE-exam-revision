DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL blank for local SQLite.
# PostgreSQL example:
# DATABASE_URL=postgres://exam_vle:password@localhost:5432/exam_vle
DATABASE_URL=

# Future generated-question provider hook.
QUESTION_GENERATOR_PROVIDER=local
QUESTION_GENERATOR_API_KEY=
